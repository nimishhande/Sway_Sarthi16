# ==========================================
# SWAY SARTHI - ENVIRONMENT VARIABLES
# ==========================================

# 1. Supabase Database & Auth (Client-Side)
# These are exposed to the browser to upload files and perform client operations.
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# 2. Supabase Database & Auth (Server-Side)
# These are used by TanStack Start server functions and middleware.
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# 3. Supabase Admin (Server-Side ONLY)
# Used to bypass Row Level Security for trusted backend operations. NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# 4. Email Notifications (Resend)
# Used to send booking confirmation emails to customers and the owner.
RESEND_API_KEY="re_..."

# 5. WhatsApp Notifications (Facebook Cloud API)
# Used to send WhatsApp alerts to the owner.
WHATSAPP_TOKEN="EAA..."
WHATSAPP_PHONE_NUMBER_ID="1234567890"

# 6. Contact Details
# Where to send the notifications.
OWNER_EMAIL="rickyramteke40@gmail.com"
OWNER_WHATSAPP="+919876543210"
